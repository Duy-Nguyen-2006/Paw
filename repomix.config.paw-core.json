{
  "$schema": "https://repomix.com/schemas/repomix-schema.json",
  "output": {
    "filePath": "repomix-output-paw-core.xml",
    "style": "xml",
    "parsableStyle": false,
    "headerText": "Paw core only (runtime, spec, stories, Paw tests). Full monorepo: repomix-output.xml",
    "fileSummary": true,
    "directoryStructure": true,
    "topFilesLength": 15
  },
  "include": [
    "packages/coding-agent/src/paw/**",
    "packages/coding-agent/test/paw-*.test.ts",
    "packages/coding-agent/test/paw-cli-e2e-validation.test.ts",
    "paw-spec/**",
    "SPEC.md",
    "README.md",
    "AGENTS.md",
    "docs/TEST_MATRIX.md",
    "docs/product/**",
    "docs/HARNESS.md",
    "docs/ARCHITECTURE.md",
    "docs/stories/epics/E01-paw-foundation/**",
    "repomix.config.json",
    "repomix.config.paw-core.json"
  ],
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      "**/dist/**",
      "harness.db",
      ".scannerwork/**",
      "repomix-output.xml",
      "repomix-output-paw-core.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
